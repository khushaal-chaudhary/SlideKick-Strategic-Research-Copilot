# Copy to .env and fill in your own values. Never commit .env.

# Neo4j (Aura free tier: https://neo4j.com/cloud/aura/)
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# LLM providers
LLM_PROVIDER=groq                # groq | ollama | gemini | openai
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GOOGLE_API_KEY=                  # Gemini (used as eval judge + BYOD extraction)
OLLAMA_BASE_URL=http://localhost:11434

# Tools
TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
